#!/usr/bin/env python3
"""Universal web scraper — Playwright-based, outputs JSON.

Usage:
  faras-scrape url <url> [--selector <css>] [--attr <name>] [--wait <seconds>]
  faras-scrape text <url> [--selector <css>] [--wait <seconds>]
  faras-scrape links <url> [--selector <css>] [--wait <seconds>]
  faras-scrape table <url> [--selector <css>] [--wait <seconds>]
  faras-scrape screenshot <url> [--output <path>] [--full]
  faras-scrape forms <url> [--wait <seconds>]
  faras-scrape meta <url> [--wait <seconds>]

Examples:
  faras-scrape text https://example.com
  faras-scrape text https://example.com --selector "h1, h2, h3"
  faras-scrape links https://example.com --selector "a[href]"
  faras-scrape table https://example.com --selector "table"
  faras-scrape screenshot https://example.com --output /tmp/page.png --full
  faras-scrape meta https://example.com
  faras-scrape forms https://login.example.com
"""
import sys, json, argparse
from playwright.sync_api import sync_playwright


def scrape_text(page, selector=None, wait=3):
    page.wait_for_timeout(wait * 1000)
    if selector:
        elements = page.query_selector_all(selector)
        return [el.inner_text().strip() for el in elements if el.inner_text().strip()]
    return [page.inner_text("body").strip()]


def scrape_links(page, selector=None, wait=3):
    page.wait_for_timeout(wait * 1000)
    sel = selector or "a[href]"
    links = page.query_selector_all(sel)
    results = []
    for link in links:
        href = link.get_attribute("href") or ""
        text = link.inner_text().strip()
        if href and not href.startswith("javascript:"):
            results.append({"text": text[:200], "url": href})
    return results


def scrape_table(page, selector=None, wait=3):
    page.wait_for_timeout(wait * 1000)
    sel = selector or "table"
    tables = page.query_selector_all(sel)
    results = []
    for table in tables:
        headers = []
        header_els = table.query_selector_all("th")
        for th in header_els:
            headers.append(th.inner_text().strip())
        rows = []
        trs = table.query_selector_all("tbody tr")
        for tr in trs:
            cells = tr.query_selector_all("td")
            row = {}
            for i, td in enumerate(cells):
                key = headers[i] if i < len(headers) else f"col_{i}"
                row[key] = td.inner_text().strip()
            rows.append(row)
        results.append({"headers": headers, "rows": rows})
    return results


def scrape_meta(page, wait=3):
    page.wait_for_timeout(wait * 1000)
    meta = {"url": page.url, "title": page.title()}
    # Open Graph
    og_tags = ["og:title", "og:description", "og:image", "og:url", "og:type",
                "og:site_name", "og:locale"]
    for tag in og_tags:
        el = page.query_selector(f'meta[property="{tag}"]')
        if el:
            meta[tag.replace("og:", "og_")] = el.get_attribute("content") or ""
    # Twitter Card
    tw_tags = ["twitter:card", "twitter:title", "twitter:description", "twitter:image"]
    for tag in tw_tags:
        el = page.query_selector(f'meta[name="{tag}"]')
        if el:
            meta[tag.replace("twitter:", "tw_")] = el.get_attribute("content") or ""
    # Standard meta
    desc_el = page.query_selector('meta[name="description"]')
    if desc_el:
        meta["description"] = desc_el.get_attribute("content") or ""
    # Favicon
    fav = page.query_selector('link[rel="icon"]')
    if fav:
        meta["favicon"] = fav.get_attribute("href") or ""
    return meta


def scrape_forms(page, wait=3):
    page.wait_for_timeout(wait * 1000)
    forms = page.query_selector_all("form")
    results = []
    for form in forms:
        action = form.get_attribute("action") or ""
        method = form.get_attribute("method") or "GET"
        inputs = form.query_selector_all("input, select, textarea")
        fields = []
        for inp in inputs:
            fields.append({
                "type": inp.get_attribute("type") or "text",
                "name": inp.get_attribute("name") or "",
                "placeholder": inp.get_attribute("placeholder") or "",
                "value": inp.get_attribute("value") or "",
                "required": inp.get_attribute("required") is not None,
            })
        results.append({"action": action, "method": method.upper(), "fields": fields})
    return results


def scrape_url_elements(page, selector=None, attr=None, wait=3):
    page.wait_for_timeout(wait * 1000)
    sel = selector or "*"
    elements = page.query_selector_all(sel)
    results = []
    for el in elements:
        if attr:
            val = el.get_attribute(attr)
            if val:
                results.append(val)
        else:
            results.append(el.inner_text().strip()[:500])
    return [r for r in results if r]


def take_screenshot(page, output=None, full=False, wait=3):
    page.wait_for_timeout(wait * 1000)
    path = output or "/tmp/scrape_screenshot.png"
    page.screenshot(path=path, full_page=full)
    return {"path": path, "full_page": full, "url": page.url, "title": page.title()}


def main():
    parser = argparse.ArgumentParser(description="Universal web scraper")
    parser.add_argument("command", choices=["url", "text", "links", "table", "screenshot", "forms", "meta"])
    parser.add_argument("target", help="URL to scrape")
    parser.add_argument("--selector", "-s", help="CSS selector")
    parser.add_argument("--attr", "-a", help="Attribute to extract")
    parser.add_argument("--output", "-o", help="Output path (screenshot)")
    parser.add_argument("--full", action="store_true", help="Full page screenshot")
    parser.add_argument("--wait", "-w", type=int, default=3, help="Wait seconds (default 3)")
    args = parser.parse_args()

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        page = browser.new_page()
        page.goto(args.target, timeout=30000)

        cmd_map = {
            "url": lambda: scrape_url_elements(page, args.selector, args.attr, args.wait),
            "text": lambda: scrape_text(page, args.selector, args.wait),
            "links": lambda: scrape_links(page, args.selector, args.wait),
            "table": lambda: scrape_table(page, args.selector, args.wait),
            "screenshot": lambda: take_screenshot(page, args.output, args.full, args.wait),
            "forms": lambda: scrape_forms(page, args.wait),
            "meta": lambda: scrape_meta(page, args.wait),
        }

        result = cmd_map[args.command]()
        browser.close()

    print(json.dumps(result, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
