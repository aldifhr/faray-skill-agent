#!/usr/bin/env python3
"""GitHub operations via gh CLI wrapper.

Usage:
  faras-gh repo list [owner] [-L N]
  faras-gh repo create <name> [--public|--private]
  faras-gh pr list <repo> [-s open|closed|all] [-L N]
  faras-gh pr create <repo> -t "title" -b "body" [-H branch]
  faras-gh issue list <repo> [-s open|closed|all] [-L N]
  faras-gh issue create <repo> -t "title" -b "body"
  faras-gh release list <repo> [-L N]
  faras-gh search repos <query> [-L N]
  faras-gh file <repo> <path> [-r branch]
  faras-gh fork <repo>
  faras-gh contributors <repo>

All extra args after the command are passed directly to gh.
Examples:
  faras-gh repo list -L 5
  faras-gh pr list aldifhr/JATracker -s open -L 10
  faras-gh issue create aldifhr/faray-skill-agent -t "Bug: X" -b "Description"
  faras-gh search repos "playwright automation" -L 5
  faras-gh file aldifhr/faray-skill-agent README.md
  faras-gh repo list --json name,description -L 5
"""
import sys, json, subprocess


def run_gh_passthrough(gh_args):
    """Run gh CLI with args passed through directly. Return parsed JSON or raw output."""
    try:
        # First try JSON output
        result = subprocess.run(
            ["gh"] + gh_args + ["--json"],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0 and result.stdout.strip():
            try:
                return json.loads(result.stdout)
            except json.JSONDecodeError:
                pass

        # Fallback: raw output
        result = subprocess.run(
            ["gh"] + gh_args,
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            return {"output": result.stdout.strip()}
        else:
            return {"error": result.stderr.strip()}
    except FileNotFoundError:
        return {"error": "gh CLI not installed. Install: https://cli.github.com/"}
    except Exception as e:
        return {"error": str(e)}


def main():
    if len(sys.argv) < 2:
        print(json.dumps({
            "usage": "faras-gh <command> [args...]",
            "commands": ["repo", "pr", "issue", "release", "search", "fork", "file", "contributors"],
            "examples": [
                "faras-gh repo list -L 5",
                "faras-gh pr list aldifhr/JATracker -s open",
                "faras-gh issue create aldifhr/repo -t 'title' -b 'body'",
                "faras-gh search repos 'playwright' -L 5",
            ]
        }))
        sys.exit(1)

    # Pass everything after script name directly to gh
    gh_args = sys.argv[1:]
    result = run_gh_passthrough(gh_args)
    print(json.dumps(result, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
